# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_URL=

# Environment
EXPO_PUBLIC_ENV=local
EXPO_PUBLIC_ANALYTICS_ENABLED=false
EXPO_PUBLIC_ANALYTICS_ENDPOINT=
EXPO_PUBLIC_ANALYTICS_WRITE_KEY=
EXPO_PUBLIC_ANALYTICS_FLUSH_INTERVAL_MS=15000

# Native Android map rendering
ANDROID_GOOGLE_MAPS_API_KEY=

# Server-side Google Places lookup
GOOGLE_PLACES_API_KEY=

# AdMob
# Local builds fall back to Google's Android/iOS test app ids when the native ids stay blank.
ANDROID_ADMOB_APP_ID=
IOS_ADMOB_APP_ID=
EXPO_PUBLIC_ADMOB_CODE_REVEAL_ENABLED=false
EXPO_PUBLIC_ADMOB_CODE_REVEAL_UNIT_ID=
# Set true only after the AdMob server-side verification callback writes rewarded unlock verification rows.
EXPO_PUBLIC_ADMOB_REWARD_SSV_ENABLED=false

# EAS Build
EAS_PROJECT_ID=
