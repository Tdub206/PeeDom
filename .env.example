# Supabase Configuration (Client-Side Public Keys)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Environment
EXPO_PUBLIC_ENV=local

# API Base URL (use your local IP for physical device testing)
# Examples:
# - Emulator/Simulator: http://localhost:3000 or http://10.0.2.2:3000
# - Physical device: http://192.168.1.xxx:3000 (your local network IP)
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:3000

# EAS Build (not needed for local development)
EAS_PROJECT_ID=

# Android Maps (only needed for Android builds)
ANDROID_GOOGLE_MAPS_API_KEY=
```

