{
  "name": "peedom-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "android:prebuild": "expo prebuild --platform android --clean",
    "android:assembleDebug": "node -e \"const { spawnSync } = require('node:child_process'); const isWin = process.platform === 'win32'; const command = isWin ? 'gradlew.bat' : './gradlew'; const result = spawnSync(command, ['assembleDebug'], { cwd: 'android', stdio: 'inherit', shell: isWin }); process.exit(result.status ?? 1);\"",
    "lint": "eslint .",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "check-deps": "npx expo install --check"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.39.7",
    "@tanstack/react-query": "^5.28.4",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.0.1",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-map-clustering": "^4.0.0",
    "react-native-maps": "^1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "~29.7.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.2"
  },
  "private": true
}
