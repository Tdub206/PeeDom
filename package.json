{
  "name": "stallpass",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node scripts/start-dev-client.cjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "android:prebuild": "expo prebuild --platform android --clean",
    "android:assembleDebug": "node scripts/android-tooling.cjs gradle assembleDebug",
    "android:assembleDebug:emulator": "node scripts/android-tooling.cjs gradle -PreactNativeArchitectures=x86_64 assembleDebug",
    "android:studio": "node scripts/android-tooling.cjs studio",
    "ai:loop": "node scripts/stallpass-ai-orchestrator.cjs loop",
    "ai:plan": "node scripts/stallpass-ai-orchestrator.cjs plan",
    "ai:review": "node scripts/stallpass-ai-orchestrator.cjs review",
    "ai:launch": "node scripts/stallpass-ai-orchestrator.cjs launch",
    "crawl:public-restrooms:arcgis": "node --experimental-strip-types scripts/crawl-arcgis-public-restrooms.ts",
    "fetch:public-restrooms:overpass": "node --experimental-strip-types scripts/fetch-overpass-public-restrooms.ts",
    "import:public-restrooms:overpass:us": "node --experimental-strip-types scripts/import-overpass-us-bulk.ts",
    "import:public-restrooms": "node --experimental-strip-types scripts/import-public-restrooms.ts",
    "lint": "eslint .",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "check-deps": "npx expo install --check",
    "store:ready": "node scripts/verify-store-readiness.cjs",
    "store:ready:urls": "node scripts/verify-store-readiness.cjs --check-urls",
    "store:metadata:lint": "npx eas-cli metadata:lint --profile production",
    "release:eas:build": "npx eas-cli env:exec production \"npx eas-cli build --platform all --profile production --non-interactive\" --non-interactive",
    "release:eas:build-submit": "npx eas-cli env:exec production \"npx eas-cli build --platform all --profile production --non-interactive --auto-submit\" --non-interactive",
    "release:eas:submit:latest": "npx eas-cli env:exec production \"npx eas-cli submit --platform all --profile production --latest --non-interactive\" --non-interactive",
    "firebase:deploy": "npx firebase-tools deploy",
    "firebase:deploy:hosting": "npx firebase-tools deploy --only hosting",
    "firebase:deploy:business-web": "npx firebase-tools deploy --only apphosting:stallpass-business-web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.39.7",
    "@tanstack/react-query": "^5.28.4",
    "adb": "^0.2.0",
    "expo": "~54.0.34",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.17",
    "firebase-cli": "^1.2.0",
    "nativewind": "^4.0.1",
    "react": "^19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.2.3",
    "react-native-map-clustering": "^4.0.0",
    "react-native-maps": "^1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "~29.7.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.2"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "private": true
}
