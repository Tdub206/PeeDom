# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# Anthropic - required for the AI assistant panel (/api/ai)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase - must match the same project as the Expo mobile app
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Local dev origin for auth callbacks and absolute links
NEXT_PUBLIC_SITE_URL=http://localhost:3030
