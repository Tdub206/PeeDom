# Supabase project URL. Must match the same project the mobile
# app (../../app.config.ts) talks to, otherwise mobile/web writes
# won't show up on each other.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key for browser/server clients. Safe to expose —
# RLS enforces per-user access on the database side.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Fully-qualified origin used for email links and auth callbacks.
# Example: https://business.stallpass.app
NEXT_PUBLIC_SITE_URL=http://localhost:3030
